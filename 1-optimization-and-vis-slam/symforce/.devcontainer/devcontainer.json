{
    "name": "Hybrid C++/Python Env",
    "build": {
        "dockerfile": "../Dockerfile"
    },
    "workspaceFolder": "/workspace",
    "workspaceMount": "source=${localWorkspaceFolder}/../..,target=/workspace,type=bind,consistency=cached",
    "remoteUser": "devuser",
    "remoteEnv": {
        "PATH": "/home/devuser/.local/bin:${containerEnv:PATH}"
    },
    "forwardPorts": [9749],
    "mounts": [
        "source=cbm-cache,target=/home/devuser/.cache/codebase-memory-mcp,type=volume"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "ms-python.python",
                "charliermarsh.ruff",
                "ms-toolsai.jupyter"
            ]
        }
    },
    "postCreateCommand": "cd 1-optimization-and-vis-slam/symforce && uv sync && cd /workspace && bash scripts/setup.sh"
}
